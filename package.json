{
  "name": "lumoshot",
  "private": true,
  "version": "1.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.web.ts",
    "dev:ext": "vite build --watch --config vite.config.extension.ts",
    "typecheck": "tsc -b",
    "build:ext": "vite build --config vite.config.extension.ts",
    "build:web": "vite build --config vite.config.web.ts",
    "build": "npm run typecheck && npm run build:ext && npm run build:web",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview --config vite.config.web.ts"
  },
  "dependencies": {
    "@types/chrome": "^0.1.36",
    "@types/fabric": "^5.3.11",
    "dexie": "^4.3.0",
    "fabric": "^7.1.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.7"
  }
}
